    <!-- ════════════════════════════════════════════════
         JavaScript
         ════════════════════════════════════════════════ -->
    <script is:inline>
      // ── Scroll Animations ─────────────────────────────
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15 });
      document.querySelectorAll('.slide-in').forEach(el => observer.observe(el));

      // ── Text Scramble Effect on Hero Name ─────────────
      (function scrambleHero() {
        const nameEl = document.getElementById('hero-name');
        if (!nameEl) return;
        const spans = nameEl.querySelectorAll('span');
        const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ!@#$%&*<>?/|\\';
        const originalTexts = [];

        spans.forEach(span => {
          originalTexts.push(span.textContent);
        });

        function scrambleLine(span, target, callback) {
          let iteration = 0;
          const maxIterations = target.length * 4;
          const interval = setInterval(() => {
            let result = '';
            for (let i = 0; i < target.length; i++) {
              if (i < Math.floor(iteration / 4)) {
                result += target[i];
              } else {
                result += chars[Math.floor(Math.random() * chars.length)];
              }
            }
            span.textContent = result;
            iteration++;
            if (iteration > maxIterations) {
              clearInterval(interval);
              span.textContent = target;
              if (callback) callback();
            }
          }, 35);
        }

        // Stagger each line
        let delay = 300;
        spans.forEach((span, index) => {
          const target = originalTexts[index];
          span.textContent = '';
          setTimeout(() => {
            scrambleLine(span, target);
          }, delay + index * 500);
        });
      })();
    </script>
