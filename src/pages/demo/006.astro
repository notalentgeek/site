---
/* Demo 006 — Paco Minimal (standalone) */
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Ultra-minimal portfolio demo" />
    <title>Demo 006 — Paco Minimal</title>
    <script is:inline>
      (function () {
        const theme = localStorage.getItem("theme-006");
        if (
          theme === "dark" ||
          (!theme && window.matchMedia("(prefers-color-scheme: dark)").matches)
        ) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body>
    <!-- Back link -->
    <a href="/site/" class="back-link">&larr; Back to index</a>

    <!-- Dark mode toggle -->
    <div class="toggle-wrap">
      <button
        id="theme-toggle"
        type="button"
        class="toggle-btn"
        aria-label="Toggle dark mode"
      >
        <span id="icon-light" class="icon-light">&#9788;</span>
        <span id="icon-dark" class="icon-dark">&#9789;</span>
      </button>
    </div>

    <!-- Main content -->
    <main class="main-col">
      <!-- Header -->
      <section class="section section-header">
        <h1 class="name">Paco Coursey</h1>
        <p class="tagline">Crafting interfaces</p>
      </section>

      <!-- Building -->
      <section class="section">
        <h2 class="section-label">Building</h2>
        <ul class="item-list">
          <li>
            <a href="https://linear.app" class="item-link" target="_blank" rel="noopener noreferrer">Linear</a>
            <span class="item-desc">&mdash; Software project management</span>
          </li>
          <li>
            <a href="https://cmdk.paco.me" class="item-link" target="_blank" rel="noopener noreferrer">cmdk</a>
            <span class="item-desc">&mdash; Fast, composable command menu</span>
          </li>
        </ul>
      </section>

      <!-- Projects -->
      <section class="section">
        <h2 class="section-label">Projects</h2>
        <ul class="item-list">
          <li>
            <a href="https://github.com/pacocoursey/next-themes" class="item-link" target="_blank" rel="noopener noreferrer">next-themes</a>
            <span class="item-desc">&mdash; Perfect dark mode in Next.js</span>
          </li>
          <li>
            <a href="https://rauno.me" class="item-link" target="_blank" rel="noopener noreferrer">rauno.me</a>
            <span class="item-desc">&mdash; Personal site for a friend</span>
          </li>
          <li>
            <a href="https://github.com/pacocoursey/paco.me" class="item-link" target="_blank" rel="noopener noreferrer">paco.me</a>
            <span class="item-desc">&mdash; This website</span>
          </li>
        </ul>
      </section>

      <!-- Writing -->
      <section class="section">
        <h2 class="section-label">Writing</h2>

        <!-- 2026 -->
        <div class="year-group">
          <h3 class="year-label">2026</h3>
          <ul class="item-list">
            <li>
              <a href="#" class="item-link">Hello World</a>
              <span class="item-date">Mar</span>
            </li>
          </ul>
        </div>

        <!-- 2025 -->
        <div class="year-group">
          <h3 class="year-label">2025</h3>
          <ul class="item-list">
            <li>
              <a href="#" class="item-link">On Design Engineering</a>
              <span class="item-date">Nov</span>
            </li>
            <li>
              <a href="#" class="item-link">Command Menus</a>
              <span class="item-date">Jun</span>
            </li>
          </ul>
        </div>

        <a href="#" class="all-link">All articles &rarr;</a>
      </section>

      <!-- Now -->
      <section class="section">
        <h2 class="section-label">Now</h2>
        <p class="now-text">
          Interested in design systems, interaction patterns, and the craft of
          building interfaces that feel right. Spending time learning about
          typography, animation, and the small details that make software feel alive.
        </p>
      </section>

      <!-- Connect -->
      <section class="section">
        <h2 class="section-label">Connect</h2>
        <ul class="item-list connect-list">
          <li>
            <a href="mailto:hello@example.com" class="connect-link">hello@example.com</a>
          </li>
          <li>
            <a href="https://github.com" class="connect-link" target="_blank" rel="noopener noreferrer">GitHub</a>
          </li>
          <li>
            <a href="https://twitter.com" class="connect-link" target="_blank" rel="noopener noreferrer">Twitter</a>
          </li>
        </ul>
      </section>

      <!-- Footer -->
      <footer class="site-footer">
        <p class="footer-quote">
          "The details are not the details. They make the design."
        </p>
        <p class="footer-attr">&mdash; Charles Eames</p>
      </footer>
    </main>

    <script is:inline>
      document
        .getElementById("theme-toggle")
        .addEventListener("click", function () {
          var html = document.documentElement;
          html.classList.toggle("dark");
          localStorage.setItem(
            "theme-006",
            html.classList.contains("dark") ? "dark" : "light"
          );
        });
    </script>
  </body>
</html>

<style>
  /* ===== Reset & Base ===== */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    background-color: #fafafa;
  }

  html.dark {
    background-color: #111111;
  }

  body {
    min-height: 100vh;
    background-color: #fafafa;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
      "Helvetica Neue", Arial, sans-serif;
    color: #171717;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  html.dark body {
    background-color: #111111;
    color: #ededed;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  ul {
    list-style: none;
  }

  /* ===== Back Link ===== */
  .back-link {
    position: fixed;
    top: 1rem;
    left: 1rem;
    z-index: 100;
    font-size: 0.875rem;
    font-weight: 500;
    color: #171717;
    text-decoration: none;
    padding: 0.25rem 0;
    transition: opacity 0.2s;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  html.dark .back-link {
    color: #ededed;
  }

  /* ===== Dark Mode Toggle ===== */
  .toggle-wrap {
    max-width: 520px;
    margin: 0 auto;
    padding: 1.5rem 1.25rem 0;
    display: flex;
    justify-content: flex-end;
  }

  .toggle-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 0.875rem;
    color: #6b6b6b;
    padding: 0.25rem;
    transition: color 0.2s;
  }

  .toggle-btn:hover {
    color: #171717;
  }

  html.dark .toggle-btn {
    color: #999999;
  }

  html.dark .toggle-btn:hover {
    color: #ededed;
  }

  /* Light mode: show moon, hide sun */
  .icon-light {
    display: none;
  }

  .icon-dark {
    display: inline;
  }

  /* Dark mode: show sun, hide moon */
  html.dark .icon-light {
    display: inline;
  }

  html.dark .icon-dark {
    display: none;
  }

  /* ===== Main Column ===== */
  .main-col {
    max-width: 520px;
    margin: 0 auto;
    padding: 0 1.25rem 6rem;
  }

  /* ===== Sections ===== */
  .section {
    padding-bottom: 5rem;
  }

  .section-header {
    padding-top: 4rem;
  }

  /* ===== Header ===== */
  .name {
    font-size: 1rem;
    font-weight: 400;
  }

  .tagline {
    margin-top: 0.25rem;
    color: #6b6b6b;
  }

  html.dark .tagline {
    color: #999999;
  }

  /* ===== Section Labels ===== */
  .section-label {
    font-size: 0.875rem;
    font-weight: 400;
    color: #a0a0a0;
    margin-bottom: 1.5rem;
  }

  html.dark .section-label {
    color: #666666;
  }

  /* ===== Item Lists ===== */
  .item-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .item-link {
    text-decoration: none;
    transition: text-decoration 0.1s;
  }

  .item-link:hover {
    text-decoration: underline;
  }

  .item-desc {
    color: #6b6b6b;
  }

  html.dark .item-desc {
    color: #999999;
  }

  .item-date {
    color: #6b6b6b;
    font-size: 0.875rem;
    margin-left: 0.5rem;
  }

  html.dark .item-date {
    color: #999999;
  }

  /* ===== Year Groups ===== */
  .year-group {
    margin-bottom: 2rem;
  }

  .year-label {
    font-size: 0.75rem;
    font-weight: 400;
    color: #a0a0a0;
    margin-bottom: 1rem;
  }

  html.dark .year-label {
    color: #666666;
  }

  /* ===== All Articles Link ===== */
  .all-link {
    font-size: 0.875rem;
    color: #6b6b6b;
    text-decoration: none;
  }

  .all-link:hover {
    text-decoration: underline;
  }

  html.dark .all-link {
    color: #999999;
  }

  /* ===== Now ===== */
  .now-text {
    color: #6b6b6b;
    line-height: 1.625;
  }

  html.dark .now-text {
    color: #999999;
  }

  /* ===== Connect ===== */
  .connect-link {
    color: #171717;
    text-decoration: none;
  }

  .connect-link:hover {
    text-decoration: underline;
  }

  html.dark .connect-link {
    color: #ededed;
  }

  /* ===== Footer ===== */
  .site-footer {
    border-top: 1px solid rgba(160, 160, 160, 0.2);
    padding-top: 2rem;
    padding-bottom: 1rem;
  }

  html.dark .site-footer {
    border-top-color: rgba(102, 102, 102, 0.2);
  }

  .footer-quote {
    font-size: 0.875rem;
    color: #a0a0a0;
    line-height: 1.625;
  }

  html.dark .footer-quote {
    color: #666666;
  }

  .footer-attr {
    font-size: 0.75rem;
    color: #a0a0a0;
    margin-top: 0.5rem;
  }

  html.dark .footer-attr {
    color: #666666;
  }
</style>
