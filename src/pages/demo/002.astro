<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Bold Creative Portfolio" />
    <title>Demo 002 — Bold Creative</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <style>
      /* Reset & Base */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      html { scroll-behavior: smooth; }

      body {
        background-color: #0a0a0a;
        color: #ffffff;
        font-family: "Inter", system-ui, -apple-system, sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      /* Scrollbar */
      ::-webkit-scrollbar { width: 8px; }
      ::-webkit-scrollbar-track { background: #0a0a0a; }
      ::-webkit-scrollbar-thumb { background: #8b5cf6; border-radius: 4px; }
      ::-webkit-scrollbar-thumb:hover { background: #a78bfa; }

      /* Selection */
      ::selection { background: rgba(139, 92, 246, 0.3); color: white; }

      /* Back link */
      .back-link {
        position: fixed;
        top: 1.25rem;
        left: 1.5rem;
        z-index: 100;
        font-size: 0.875rem;
        color: rgba(255, 255, 255, 0.4);
        text-decoration: none;
        transition: color 0.3s;
        font-weight: 500;
      }
      .back-link:hover { color: #22d3ee; }

      /* Header */
      .site-header {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 50;
        transition: all 0.5s ease-out;
      }
      .header-bg {
        position: absolute;
        inset: 0;
        background-color: rgba(10, 10, 10, 0);
        backdrop-filter: none;
        transition: all 0.5s;
      }
      .site-header.scrolled .header-bg {
        background-color: rgba(10, 10, 10, 0.85);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-bottom: 1px solid rgba(139, 92, 246, 0.1);
      }
      .site-header nav {
        position: relative;
        max-width: 80rem;
        margin: 0 auto;
        padding: 1.25rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        transition: padding 0.5s;
      }
      .site-header.scrolled nav {
        padding-top: 0.75rem;
        padding-bottom: 0.75rem;
      }
      .header-logo {
        font-size: 1.5rem;
        font-weight: 800;
        letter-spacing: -0.05em;
        text-decoration: none;
        background: linear-gradient(to right, #8b5cf6, #22d3ee);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        transition: all 0.5s;
      }
      .header-logo:hover {
        background: linear-gradient(to right, #22d3ee, #8b5cf6);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .nav-links {
        display: flex;
        align-items: center;
        gap: 2rem;
        list-style: none;
        font-size: 0.875rem;
        font-weight: 500;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }
      .nav-links a {
        color: rgba(255, 255, 255, 0.6);
        text-decoration: none;
        transition: color 0.3s;
        position: relative;
      }
      .nav-links a::after {
        content: "";
        position: absolute;
        bottom: -4px; left: 0;
        width: 0; height: 2px;
        background: #22d3ee;
        transition: width 0.3s;
      }
      .nav-links a:hover { color: #22d3ee; }
      .nav-links a:hover::after { width: 100%; }

      /* Hero */
      .hero {
        position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
      }
      .hero-gradient-bg {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(139, 92, 246, 0.2), #0a0a0a, rgba(34, 211, 238, 0.2));
        background-size: 400% 400%;
        animation: gradient-shift 8s ease infinite;
      }
      .hero-glow-1 {
        position: absolute;
        top: 25%; left: 25%;
        width: 24rem; height: 24rem;
        background: rgba(139, 92, 246, 0.1);
        border-radius: 50%;
        filter: blur(120px);
        animation: pulse-glow 3s ease-in-out infinite;
      }
      .hero-glow-2 {
        position: absolute;
        bottom: 25%; right: 25%;
        width: 24rem; height: 24rem;
        background: rgba(34, 211, 238, 0.1);
        border-radius: 50%;
        filter: blur(120px);
        animation: pulse-glow 3s ease-in-out infinite;
        animation-delay: 1.5s;
      }
      .hero-grid-overlay {
        position: absolute;
        inset: 0;
        opacity: 0.03;
        background-image:
          linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px);
        background-size: 60px 60px;
      }
      .hero-content {
        position: relative;
        z-index: 10;
        max-width: 64rem;
        margin: 0 auto;
        padding: 0 1.5rem;
        text-align: center;
        animation: fade-in-up 0.6s ease-out forwards;
      }
      .hero-subtitle {
        color: #22d3ee;
        font-size: 0.875rem;
        font-weight: 600;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        margin-bottom: 1.5rem;
      }
      .hero-title {
        font-size: 3.75rem;
        font-weight: 900;
        letter-spacing: -0.05em;
        line-height: 0.85;
        margin-bottom: 2rem;
      }
      @media (min-width: 768px) { .hero-title { font-size: 6rem; } }
      @media (min-width: 1024px) { .hero-title { font-size: 8rem; } }
      .hero-title .line-white { display: block; color: #ffffff; }
      .hero-title .line-gradient {
        display: block;
        background: linear-gradient(to right, #8b5cf6, #22d3ee, #8b5cf6);
        background-size: 200% auto;
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        animation: gradient-shift 8s ease infinite;
      }
      .hero-description {
        color: rgba(255, 255, 255, 0.4);
        font-size: 1.125rem;
        max-width: 42rem;
        margin: 0 auto 3rem;
        line-height: 1.75;
      }
      @media (min-width: 768px) { .hero-description { font-size: 1.25rem; } }
      .hero-buttons {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
      }
      .btn-primary {
        display: inline-block;
        padding: 1rem 2rem;
        background: #8b5cf6;
        color: #fff;
        font-weight: 600;
        font-size: 0.875rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        text-decoration: none;
        border-radius: 9999px;
        transition: all 0.3s;
      }
      .btn-primary:hover {
        background: #a78bfa;
        box-shadow: 0 10px 25px rgba(139, 92, 246, 0.3);
      }
      .btn-secondary {
        display: inline-block;
        padding: 1rem 2rem;
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: rgba(255, 255, 255, 0.7);
        font-weight: 600;
        font-size: 0.875rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        text-decoration: none;
        border-radius: 9999px;
        transition: all 0.3s;
      }
      .btn-secondary:hover {
        border-color: #22d3ee;
        color: #22d3ee;
      }
      .scroll-indicator {
        position: absolute;
        bottom: 2rem;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
      }
      .scroll-indicator span {
        color: rgba(255, 255, 255, 0.2);
        font-size: 0.75rem;
        letter-spacing: 0.3em;
        text-transform: uppercase;
      }
      .scroll-indicator .scroll-line {
        width: 1px;
        height: 3rem;
        background: linear-gradient(to bottom, rgba(255,255,255,0.2), transparent);
      }

      /* Section container */
      .section-container {
        max-width: 80rem;
        margin: 0 auto;
        padding: 6rem 1.5rem;
      }

      /* Section header */
      .section-label {
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        margin-bottom: 0.75rem;
      }
      .label-purple { color: #8b5cf6; }
      .label-cyan { color: #22d3ee; }
      .section-title {
        font-size: 2.25rem;
        font-weight: 900;
        letter-spacing: -0.05em;
        text-transform: uppercase;
      }
      @media (min-width: 768px) { .section-title { font-size: 3rem; } }
      .section-top {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        margin-bottom: 3rem;
      }
      .view-all {
        color: rgba(255, 255, 255, 0.4);
        font-size: 0.875rem;
        font-weight: 500;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        text-decoration: none;
        transition: color 0.3s;
        display: none;
      }
      @media (min-width: 768px) { .view-all { display: block; } }
      .view-all:hover { color: #22d3ee; }

      /* Card grid */
      .card-grid-3 {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
      }
      @media (min-width: 768px) { .card-grid-3 { grid-template-columns: 1fr 1fr; } }
      @media (min-width: 1024px) { .card-grid-3 { grid-template-columns: 1fr 1fr 1fr; } }

      .card-grid-2 {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
      }
      @media (min-width: 768px) { .card-grid-2 { grid-template-columns: 1fr 1fr; } }

      /* Content card */
      .content-card {
        display: block;
        text-decoration: none;
        color: inherit;
        background: #141414;
        border-radius: 1rem;
        padding: 1.5rem;
        position: relative;
        overflow: hidden;
        transition: all 0.5s ease-out;
      }
      .content-card:hover {
        transform: scale(1.02);
        box-shadow: 0 25px 50px rgba(139, 92, 246, 0.1);
        outline: 1px solid rgba(139, 92, 246, 0.3);
      }
      .content-card.featured {
        outline: 1px solid rgba(139, 92, 246, 0.2);
      }
      .card-hover-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(139, 92, 246, 0), rgba(34, 211, 238, 0));
        border-radius: 1rem;
        transition: all 0.5s;
      }
      .content-card:hover .card-hover-overlay {
        background: linear-gradient(135deg, rgba(139, 92, 246, 0.05), rgba(34, 211, 238, 0.05));
      }
      .card-content {
        position: relative;
        z-index: 10;
      }
      .card-date {
        font-size: 0.75rem;
        color: rgba(255, 255, 255, 0.3);
        font-weight: 500;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        margin-bottom: 0.75rem;
        display: block;
      }
      .card-title {
        font-weight: 700;
        letter-spacing: -0.025em;
        color: #fff;
        transition: color 0.3s;
        font-size: 1.125rem;
        margin-bottom: 0.5rem;
      }
      .content-card.featured .card-title {
        font-size: 1.5rem;
        margin-bottom: 0.75rem;
      }
      .content-card:hover .card-title { color: #22d3ee; }
      .card-desc {
        color: rgba(255, 255, 255, 0.5);
        line-height: 1.75;
        transition: color 0.3s;
        font-size: 0.875rem;
        margin-bottom: 0.75rem;
      }
      .content-card.featured .card-desc {
        font-size: 1rem;
        margin-bottom: 1rem;
      }
      .content-card:hover .card-desc { color: rgba(255, 255, 255, 0.7); }
      .card-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 1rem;
      }
      .card-tag {
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        padding: 0.25rem 0.75rem;
        border-radius: 9999px;
        background: rgba(139, 92, 246, 0.1);
        color: #a78bfa;
        border: 1px solid rgba(139, 92, 246, 0.2);
        transition: background 0.3s;
      }
      .content-card:hover .card-tag { background: rgba(139, 92, 246, 0.2); }
      .card-arrow {
        margin-top: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: rgba(255, 255, 255, 0.2);
        transition: color 0.3s;
      }
      .content-card:hover .card-arrow { color: #22d3ee; }
      .card-arrow span {
        font-size: 0.75rem;
        font-weight: 500;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }
      .card-arrow svg {
        width: 1rem; height: 1rem;
        transition: transform 0.3s;
      }
      .content-card:hover .card-arrow svg { transform: translateX(4px); }

      /* Social grid */
      .social-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
      }
      @media (min-width: 768px) { .social-grid { grid-template-columns: repeat(3, 1fr); } }
      @media (min-width: 1024px) { .social-grid { grid-template-columns: repeat(6, 1fr); } }
      .social-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        padding: 1.5rem;
        border-radius: 1rem;
        background: #141414;
        text-decoration: none;
        transition: all 0.5s;
      }
      .social-card:hover {
        background: #1e1e1e;
        transform: scale(1.05);
        box-shadow: 0 20px 40px rgba(139, 92, 246, 0.1);
        outline: 1px solid rgba(139, 92, 246, 0.3);
      }
      .social-icon {
        font-size: 1.5rem;
        font-weight: 900;
        color: rgba(255, 255, 255, 0.3);
        transition: color 0.3s;
      }
      .social-card:hover .social-icon { color: #22d3ee; }
      .social-name {
        font-size: 0.75rem;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.4);
        letter-spacing: 0.05em;
        text-transform: uppercase;
        transition: color 0.3s;
      }
      .social-card:hover .social-name { color: rgba(255, 255, 255, 0.7); }

      /* Footer */
      .site-footer {
        border-top: 1px solid #2a2a2a;
        padding: 3rem 0;
        margin-top: 6rem;
      }
      .footer-inner {
        max-width: 80rem;
        margin: 0 auto;
        padding: 0 1.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }
      @media (min-width: 768px) { .footer-inner { flex-direction: row; } }
      .footer-copyright {
        color: rgba(255, 255, 255, 0.3);
        font-size: 0.875rem;
      }
      .footer-right {
        display: flex;
        align-items: center;
        gap: 1.5rem;
      }
      .footer-right a {
        color: rgba(255, 255, 255, 0.3);
        font-size: 0.875rem;
        text-decoration: none;
        transition: color 0.3s;
      }
      .footer-right a:hover { color: #8b5cf6; }
      .footer-divider {
        color: rgba(255, 255, 255, 0.1);
      }
      .footer-built {
        color: rgba(255, 255, 255, 0.3);
        font-size: 0.875rem;
      }

      /* Center text for social section */
      .text-center { text-align: center; }
      .mb-16 { margin-bottom: 4rem; }

      /* Animations */
      @keyframes gradient-shift {
        0%, 100% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
      }
      @keyframes fade-in-up {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
      }
      @keyframes pulse-glow {
        0%, 100% { opacity: 0.4; }
        50% { opacity: 0.8; }
      }
    </style>
  </head>
  <body>
    <!-- Back to index -->
    <a href="/site/" class="back-link">&larr; Back to index</a>

    <!-- Sticky Header -->
    <header class="site-header" id="site-header">
      <div class="header-bg"></div>
      <nav>
        <a href="#" class="header-logo">PORTFOLIO</a>
        <ul class="nav-links">
          <li><a href="#">Articles</a></li>
          <li><a href="#">Videos</a></li>
          <li><a href="#">Links</a></li>
        </ul>
      </nav>
    </header>

    <main>
      <!-- Hero Section -->
      <section class="hero">
        <div class="hero-gradient-bg"></div>
        <div class="hero-glow-1"></div>
        <div class="hero-glow-2"></div>
        <div class="hero-grid-overlay"></div>

        <div class="hero-content">
          <p class="hero-subtitle">Creative Developer &amp; Designer</p>
          <h1 class="hero-title">
            <span class="line-white">CRAFTING</span>
            <span class="line-gradient">DIGITAL</span>
            <span class="line-white">EXPERIENCES</span>
          </h1>
          <p class="hero-description">
            Building at the intersection of design and technology.
            Every pixel intentional. Every interaction meaningful.
          </p>
          <div class="hero-buttons">
            <a href="#" class="btn-primary">View Work</a>
            <a href="#" class="btn-secondary">Connect</a>
          </div>
        </div>

        <div class="scroll-indicator">
          <span>Scroll</span>
          <div class="scroll-line"></div>
        </div>
      </section>

      <!-- Featured Articles -->
      <section class="section-container">
        <div class="section-top">
          <div>
            <p class="section-label label-purple">Featured</p>
            <h2 class="section-title">Articles</h2>
          </div>
          <a href="#" class="view-all">View All &rarr;</a>
        </div>

        <div class="card-grid-3">
          <!-- Card 1 (featured) -->
          <a href="#" class="content-card featured">
            <div class="card-hover-overlay"></div>
            <div class="card-content">
              <time class="card-date">Mar 29, 2026</time>
              <h3 class="card-title">Hello World: Building a Bold Creative Portfolio</h3>
              <p class="card-desc">A deep dive into crafting a visually striking portfolio that stands out from the crowd.</p>
              <div class="card-tags">
                <span class="card-tag">design</span>
                <span class="card-tag">portfolio</span>
                <span class="card-tag">web</span>
              </div>
              <div class="card-arrow">
                <span>Explore</span>
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </div>
          </a>

          <!-- Card 2 -->
          <a href="#" class="content-card">
            <div class="card-hover-overlay"></div>
            <div class="card-content">
              <time class="card-date">Mar 25, 2026</time>
              <h3 class="card-title">The Art of Visual Hierarchy</h3>
              <p class="card-desc">How strategic use of scale, color, and space can guide the viewer through your work.</p>
              <div class="card-tags">
                <span class="card-tag">design</span>
                <span class="card-tag">typography</span>
              </div>
              <div class="card-arrow">
                <span>Explore</span>
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </div>
          </a>

          <!-- Card 3 -->
          <a href="#" class="content-card">
            <div class="card-hover-overlay"></div>
            <div class="card-content">
              <time class="card-date">Mar 20, 2026</time>
              <h3 class="card-title">Performance Meets Aesthetics</h3>
              <p class="card-desc">Exploring the balance between visual richness and web performance in modern portfolios.</p>
              <div class="card-tags">
                <span class="card-tag">performance</span>
                <span class="card-tag">web</span>
              </div>
              <div class="card-arrow">
                <span>Explore</span>
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </div>
          </a>
        </div>
      </section>

      <!-- Featured Videos -->
      <section class="section-container">
        <div class="section-top">
          <div>
            <p class="section-label label-cyan">Featured</p>
            <h2 class="section-title">Videos</h2>
          </div>
          <a href="#" class="view-all">View All &rarr;</a>
        </div>

        <div class="card-grid-2">
          <!-- Video Card 1 -->
          <a href="#" class="content-card">
            <div class="card-hover-overlay"></div>
            <div class="card-content">
              <time class="card-date">Mar 29, 2026</time>
              <h3 class="card-title">Creative Coding Showcase</h3>
              <p class="card-desc">A walkthrough of generative art techniques using code as a creative medium.</p>
              <div class="card-tags">
                <span class="card-tag">creative-coding</span>
                <span class="card-tag">tutorial</span>
              </div>
              <div class="card-arrow">
                <span>Explore</span>
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </div>
          </a>

          <!-- Video Card 2 -->
          <a href="#" class="content-card">
            <div class="card-hover-overlay"></div>
            <div class="card-content">
              <time class="card-date">Mar 22, 2026</time>
              <h3 class="card-title">Design System Deep Dive</h3>
              <p class="card-desc">Building a cohesive design system from scratch with tokens, components, and documentation.</p>
              <div class="card-tags">
                <span class="card-tag">design-system</span>
                <span class="card-tag">ui</span>
              </div>
              <div class="card-arrow">
                <span>Explore</span>
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </div>
          </a>
        </div>
      </section>

      <!-- Social Links Section -->
