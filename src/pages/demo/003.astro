---
// Demo 003 — Developer Terminal
// Standalone demo page — no shared layouts or components
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Demo 003 — Developer Terminal</title>
    <style>
      /* ── Reset ── */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      /* ── Theme tokens ── */
      :root {
        --bg: #0d1117;
        --bg-light: #161b22;
        --green: #00ff41;
        --green-dim: #00cc33;
        --blue: #58a6ff;
        --amber: #ffa657;
        --red: #ff7b72;
        --gray: #8b949e;
        --border: #30363d;
        --white: #c9d1d9;
      }

      /* ── Base ── */
      html { background-color: var(--bg); }
      body {
        font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas,
                     "Liberation Mono", monospace;
        color: var(--green);
        background-color: var(--bg);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        line-height: 1.6;
      }

      /* ── Selection ── */
      ::selection {
        background-color: var(--green);
        color: var(--bg);
      }

      /* ── Scrollbar ── */
      ::-webkit-scrollbar { width: 8px; }
      ::-webkit-scrollbar-track { background: var(--bg); }
      ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }
      ::-webkit-scrollbar-thumb:hover { background: #484f58; }

      /* ── CRT scanline overlay ── */
      body::before {
        content: "";
        position: fixed;
        top: 0; left: 0;
        width: 100%; height: 100%;
        pointer-events: none;
        z-index: 9999;
        background: repeating-linear-gradient(
          0deg,
          rgba(0, 0, 0, 0.03) 0px,
          rgba(0, 0, 0, 0.03) 1px,
          transparent 1px,
          transparent 2px
        );
      }

      /* ── Glow effect ── */
      .glow-text {
        text-shadow: 0 0 5px rgba(0, 255, 65, 0.4),
                     0 0 10px rgba(0, 255, 65, 0.2);
      }

      /* ── Blinking cursor ── */
      @keyframes blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0; }
      }
      .cursor-blink {
        animation: blink 1s step-end infinite;
      }

      /* ── Back link ── */
      .back-link {
        display: inline-block;
        color: var(--blue);
        text-decoration: none;
        font-size: 0.875rem;
        padding: 0.75rem 1rem;
        transition: color 0.15s;
      }
      .back-link:hover {
        color: var(--green);
      }

      /* ── Layout ── */
      .container {
        max-width: 56rem;
        margin: 0 auto;
        padding: 0 1rem;
        width: 100%;
      }

      /* ── Header ── */
      header {
        border-bottom: 1px solid var(--border);
      }
      .ascii-art {
        color: var(--green);
        font-size: 0.75rem;
        line-height: 1.2;
        white-space: pre;
        user-select: none;
      }
      @media (min-width: 640px) {
        .ascii-art { font-size: 0.875rem; }
      }
      .header-meta {
        margin-top: 0.5rem;
        color: var(--gray);
        font-size: 0.75rem;
      }

      /* ── Navigation ── */
      nav { padding-bottom: 0.75rem; }
      .nav-list {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem 1.5rem;
        list-style: none;
      }
      .nav-link {
        color: var(--green);
        text-decoration: none;
        font-size: 0.875rem;
        transition: color 0.15s;
      }
      .nav-link:hover { color: var(--blue); }
      .nav-link .chevron { color: var(--gray); }
      .nav-link:hover .chevron { color: var(--blue); }

      /* ── Prompt line ── */
      .prompt {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.875rem;
      }
      .prompt-user { color: var(--green-dim); }
      .prompt-colon { color: var(--gray); }
      .prompt-path { color: var(--blue); }
      .prompt-dollar { color: var(--white); }
      .prompt-cmd { color: var(--green); }

      /* ── Section ── */
      section { margin-bottom: 2.5rem; }

      /* ── Hero ── */
      .hero-title {
        font-size: 1.5rem;
        font-weight: bold;
        color: var(--green);
      }
      @media (min-width: 640px) {
        .hero-title { font-size: 1.875rem; }
      }
      .hero-bio {
        margin-top: 0.75rem;
        color: var(--white);
        font-size: 0.875rem;
        line-height: 1.7;
        max-width: 42rem;
      }

      /* ── Status box ── */
      .status-box {
        margin-top: 1.5rem;
        border: 1px solid var(--border);
        border-radius: 2px;
        background-color: var(--bg-light);
        padding: 1rem;
      }
      .status-comment {
        color: var(--gray);
        font-size: 0.75rem;
        margin-bottom: 0.5rem;
      }
      .status-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0.75rem;
        font-size: 0.875rem;
      }
      @media (min-width: 640px) {
        .status-grid { grid-template-columns: repeat(3, 1fr); }
      }
      .status-label { color: var(--gray); }
      .status-green { color: var(--green); }
      .status-amber { color: var(--amber); }
      .status-blue { color: var(--blue); }

      /* ── Listing panel ── */
      .listing-panel {
        margin-top: 0.75rem;
        border: 1px solid var(--border);
        border-radius: 2px;
        overflow: hidden;
      }
      .listing-header {
        background-color: var(--bg-light);
        padding: 0.5rem 1rem;
        border-bottom: 1px solid var(--border);
        font-size: 0.75rem;
        color: var(--gray);
      }
      .listing-row {
        padding: 0.75rem 1rem;
        border-bottom: 1px solid var(--border);
        transition: background-color 0.15s;
        text-decoration: none;
        display: block;
      }
      .listing-row:last-child { border-bottom: none; }
      .listing-row:hover { background-color: var(--bg-light); }
      .listing-meta {
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
        font-size: 0.875rem;
        flex-wrap: wrap;
      }
      .listing-perms { color: var(--green); }
      .listing-date { color: var(--gray); }
      .listing-title {
        color: var(--blue);
        transition: color 0.15s;
      }
      .listing-row:hover .listing-title { color: var(--green); }
      .listing-desc {
        margin-top: 0.25rem;
        padding-left: 1rem;
        font-size: 0.75rem;
        color: var(--gray);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .listing-empty {
        padding: 0.75rem 1rem;
        color: var(--gray);
        font-size: 0.875rem;
      }
      .listing-vid-tag { color: var(--amber); }

      /* ── "cd" link ── */
      .cd-link {
        display: inline-block;
        margin-top: 0.5rem;
        color: var(--blue);
        text-decoration: none;
        font-size: 0.875rem;
        transition: color 0.15s;
      }
      .cd-link:hover { color: var(--green); }
      .cd-link .chevron { color: var(--gray); }

      /* ── Footer ── */
      footer {
        border-top: 1px solid var(--border);
        margin-top: auto;
      }
      .footer-copy {
        margin-top: 0.5rem;
        color: var(--gray);
        font-size: 0.75rem;
      }

      /* ── Main area ── */
      .main-area {
        flex: 1;
        padding: 1.5rem 0;
      }
    </style>
  </head>
  <body>
    <!-- Back link -->
    <a href="/site/" class="back-link">&larr; Back to index</a>

    <!-- ASCII Art Header -->
    <header>
      <div class="container" style="padding-top: 1.5rem; padding-bottom: 1rem;">
        <pre class="ascii-art glow-text" aria-hidden="true">
 ____            _    __       _ _
|  _ \ ___  _ __| |_ / _| ___ | (_) ___
| |_) / _ \| '__| __| |_ / _ \| | |/ _ \
|  __/ (_) | |  | |_|  _| (_) | | | (_) |
|_|   \___/|_|   \__|_|  \___/|_|_|\___/</pre>
        <div class="header-meta">
          v1.0.0 | pid 1337 | uptime 99.99%
        </div>
      </div>

      <!-- Navigation -->
      <nav class="container">
        <ul class="nav-list">
          <li><a href="#" class="nav-link"><span class="chevron">&gt;</span> home</a></li>
          <li><a href="#" class="nav-link"><span class="chevron">&gt;</span> article</a></li>
          <li><a href="#" class="nav-link"><span class="chevron">&gt;</span> video</a></li>
          <li><a href="#" class="nav-link"><span class="chevron">&gt;</span> link</a></li>
        </ul>
      </nav>
    </header>

    <!-- Main Content -->
    <main class="main-area">
      <div class="container">

        <!-- Hero Section -->
        <section>
          <div class="prompt">
            <span class="prompt-user">visitor@portfolio</span>
            <span class="prompt-colon">:</span>
            <span class="prompt-path">~</span>
            <span class="prompt-dollar">$</span>
            <span class="prompt-cmd">whoami</span>
          </div>
          <div style="margin-top: 0.75rem; padding-left: 0;">
            <h1 class="hero-title glow-text">
              developer<span class="cursor-blink">_</span>
            </h1>
            <p class="hero-bio">
              Full-stack developer, systems thinker, and terminal enthusiast.
              I build things for the web and occasionally break them in interesting ways.
            </p>
          </div>

          <div class="status-box">
            <div class="status-comment">// system status</div>
            <div class="status-grid">
              <div>
                <span class="status-label">status:</span>
                <span class="status-green"> online</span>
              </div>
              <div>
                <span class="status-label">location:</span>
                <span class="status-amber"> earth/internet</span>
              </div>
              <div>
                <span class="status-label">focus:</span>
                <span class="status-blue"> web + systems</span>
              </div>
            </div>
          </div>
        </section>

        <!-- Recent Articles -->
        <section>
          <div class="prompt">
            <span class="prompt-user">visitor@portfolio</span>
            <span class="prompt-colon">:</span>
            <span class="prompt-path">~</span>
            <span class="prompt-dollar">$</span>
            <span class="prompt-cmd">ls -la ./article/ | head -5</span>
          </div>
          <div class="listing-panel">
            <div class="listing-header">total 5 entries</div>
            <a href="#" class="listing-row">
              <div class="listing-meta">
                <span class="listing-perms">-rw-r--r--</span>
                <span class="listing-date">2026-03-29</span>
                <span class="listing-title">Building a Terminal-Style Portfolio</span>
              </div>
              <div class="listing-desc">How I designed a developer portfolio that looks like a terminal.</div>
            </a>
            <a href="#" class="listing-row">
              <div class="listing-meta">
                <span class="listing-perms">-rw-r--r--</span>
                <span class="listing-date">2026-03-27</span>
                <span class="listing-title">Getting Started with Astro Framework</span>
              </div>
              <div class="listing-desc">An introduction to the content-first web framework.</div>
            </a>
            <a href="#" class="listing-row">
              <div class="listing-meta">
                <span class="listing-perms">-rw-r--r--</span>
                <span class="listing-date">2026-03-25</span>
                <span class="listing-title">CSS Grid vs Flexbox: When to Use What</span>
              </div>
              <div class="listing-desc">A practical guide to choosing the right layout system.</div>
            </a>
            <a href="#" class="listing-row">
              <div class="listing-meta">
                <span class="listing-perms">-rw-r--r--</span>
                <span class="listing-date">2026-03-22</span>
                <span class="listing-title">Automating My Dev Workflow with Shell Scripts</span>
              </div>
              <div class="listing-desc">Bash scripts that save me hours every week.</div>
            </a>
            <a href="#" class="listing-row">
              <div class="listing-meta">
                <span class="listing-perms">-rw-r--r--</span>
                <span class="listing-date">2026-03-20</span>
                <span class="listing-title">Understanding Linux File Permissions</span>
              </div>
              <div class="listing-desc">Demystifying chmod, chown, and access control.</div>
            </a>
          </div>
          <a href="#" class="cd-link">
            <span class="chevron">&gt;</span> cd article/
          </a>
        </section>

        <!-- Recent Videos -->
        <section>
          <div class="prompt">
            <span class="prompt-user">visitor@portfolio</span>
            <span class="prompt-colon">:</span>
            <span class="prompt-path">~</span>
            <span class="prompt-dollar">$</span>
            <span class="prompt-cmd">find ./video/ -type f -name '*.mp4'</span>
          </div>
          <div class="listing-panel">
            <div class="listing-header">total 3 entries</div>
            <div class="listing-row">
              <div class="listing-meta">
                <span class="listing-vid-tag">[vid]</span>
                <span class="listing-date">2026-03-28</span>
                <span class="listing-title">Terminal Customization Deep Dive</span>
              </div>
              <div class="listing-desc">Configuring zsh, tmux, and neovim for maximum productivity.</div>
            </div>
            <div class="listing-row">
              <div class="listing-meta">
                <span class="listing-vid-tag">[vid]</span>
                <span class="listing-date">2026-03-24</span>
                <span class="listing-title">Deploy with Docker in 10 Minutes</span>
              </div>
              <div class="listing-desc">From Dockerfile to production in a quick walkthrough.</div>
            </div>
            <div class="listing-row">
              <div class="listing-meta">
                <span class="listing-vid-tag">[vid]</span>
                <span class="listing-date">2026-03-19</span>
                <span class="listing-title">Git Workflow Best Practices</span>
              </div>
              <div class="listing-desc">Branching strategies, rebasing, and commit hygiene.</div>
            </div>
          </div>
          <a href="#" class="cd-link">
            <span class="chevron">&gt;</span> cd video/
          </a>
        </section>

        <!-- Quick Links -->
        <section>
          <div class="prompt">
            <span class="prompt-user">visitor@portfolio</span>
            <span class="prompt-colon">:</span>
            <span class="prompt-path">~</span>
            <span class="prompt-dollar">$</span>
            <span class="prompt-cmd">cat ./link/bookmarks.txt</span>
          </div>
          <div style="margin-top: 0.75rem; font-size: 0.875rem; color: var(--gray);">
            See saved bookmarks:
            <a href="#" class="cd-link" style="margin-top: 0;">
              <span class="chevron">&gt;</span> open link/
            </a>
          </div>
        </section>

        <!-- Interactive prompt -->
        <section>
          <div class="prompt">
            <span class="prompt-user">visitor@portfolio</span>
            <span class="prompt-colon">:</span>
            <span class="prompt-path">~/portfolio</span>
            <span class="prompt-dollar">$</span>
            <span class="cursor-blink" style="color: var(--green);">|</span>
          </div>
        </section>

      </div>
    </main>

    <!-- Footer -->
    <footer>
      <div class="container" style="padding: 1rem 1rem;">
        <div class="prompt">
          <span class="prompt-user">visitor@portfolio</span>
          <span class="prompt-colon">:</span>
          <span class="prompt-path">~</span>
          <span class="prompt-dollar">$</span>
          <span class="prompt-cmd">echo 'Thanks for visiting.'</span>
        </div>
        <div class="footer-copy">
          &copy; 2026 | Built with Astro | All rights reserved
        </div>
      </div>
    </footer>
  </body>
</html>
