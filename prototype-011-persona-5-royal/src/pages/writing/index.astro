---
import BaseLayout from "../../layouts/base_layout.astro";
import { getCollection } from "astro:content";

const articles = (await getCollection("article"))
  .filter((a) => !a.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const articlesByYear: Record<string, typeof articles> = {};
for (const article of articles) {
  const year = new Date(article.data.date).getFullYear().toString();
  if (!articlesByYear[year]) articlesByYear[year] = [];
  articlesByYear[year].push(article);
}
---
<BaseLayout title="Schedule — Phantom Thieves Portfolio">

  <section class="page-header">
    <h1 class="page-title skew-heading">Schedule</h1>
    <p class="page-desc">Operational log of the Phantom Thieves. Every mission documented.</p>
  </section>

  <section class="schedule-content">
    {Object.keys(articlesByYear).sort((a, b) => Number(b) - Number(a)).map((year) => (
      <div class="schedule-year">
        <h2 class="year-label">{year}</h2>
        <ul class="schedule-list">
          {articlesByYear[year].map((article) => (
            <li class="schedule-item">
              <span class="schedule-date">{article.data.date}</span>
              <div class="schedule-info">
                <span class="schedule-title">{article.data.title}</span>
                {article.data.description && (
                  <span class="schedule-desc">{article.data.description}</span>
                )}
                {article.data.tags && (
                  <div class="schedule-tags">
                    {article.data.tags.map((tag) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </section>

</BaseLayout>

<style>
  .page-header {
    background: #FF0000;
    padding: 4rem 2rem;
  }

  .page-title {
    font-size: 3rem;
    color: #0D0D0D;
    margin-bottom: 1rem;
  }

  .page-desc {
    font-size: 1rem;
    color: #0D0D0D;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .schedule-content {
    background: #0D0D0D;
    padding: 4rem 2rem;
  }

  .schedule-year {
    margin-bottom: 3rem;
  }

  .year-label {
    font-size: 2rem;
    font-weight: 900;
    color: #FF0000;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    border-bottom: 3px solid #FF0000;
    padding-bottom: 0.5rem;
    display: inline-block;
  }

  .schedule-list {
    list-style: none;
  }

  .schedule-item {
    display: flex;
    gap: 2rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid #2a2a2a;
    align-items: flex-start;
  }

  .schedule-date {
    font-size: 0.8rem;
    font-weight: 700;
    color: #888888;
    letter-spacing: 0.05em;
    white-space: nowrap;
    min-width: 100px;
    padding-top: 0.15rem;
  }

  .schedule-info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .schedule-title {
    font-size: 1.125rem;
    font-weight: 900;
    color: #FFFFFF;
    text-transform: uppercase;
  }

  .schedule-desc {
    font-size: 0.875rem;
    color: #888888;
    line-height: 1.5;
  }

  .schedule-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.25rem 0.75rem;
    background: #2a2a2a;
    color: #F2E852;
  }
</style>
