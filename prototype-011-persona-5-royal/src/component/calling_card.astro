---
interface Props {
  email?: string;
}
const { email = "hello@example.com" } = Astro.props;
---
<div class="calling-card">
  <div class="card-inner">
    <h2 class="card-heading">CALLING CARD</h2>
    <p class="card-body">
      Dear visitor, we have decided to make you aware of our existence.
      If you wish to make contact, send a message.
    </p>
    <p class="card-sign">From, The Phantom Thieves</p>
    <a href={`mailto:${email}`} class="card-cta">SEND A MESSAGE</a>
  </div>
  <div class="wax-seal" aria-hidden="true">PT</div>
</div>
<style>
  .calling-card {
    position: relative;
    background: #f5f0e0;
    color: #0D0D0D;
    border: 4px solid #F2E852;
    padding: 3rem 2rem;
    clip-path: polygon(
      0 0,
      100% 0,
      100% calc(100% - 24px),
      calc(100% - 12px) calc(100% - 12px),
      calc(100% - 24px) 100%,
      calc(100% - 36px) calc(100% - 8px),
      calc(100% - 48px) 100%,
      calc(100% - 60px) calc(100% - 10px),
      calc(100% - 72px) 100%,
      calc(100% - 84px) calc(100% - 6px),
      calc(100% - 96px) 100%,
      72px calc(100% - 8px),
      60px 100%,
      48px calc(100% - 12px),
      36px 100%,
      24px calc(100% - 6px),
      12px 100%,
      0 calc(100% - 20px)
    );
  }

  .card-inner {
    text-align: center;
  }

  .card-heading {
    font-size: 2.5rem;
    font-weight: 900;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    color: #CC0000;
  }

  .card-body {
    font-size: 1.125rem;
    line-height: 1.8;
    margin-bottom: 1rem;
    font-style: italic;
  }

  .card-sign {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 2rem;
    letter-spacing: 0.05em;
  }

  .card-cta {
    display: inline-block;
    background: #FF0000;
    color: #FFFFFF;
    padding: 1rem 2.5rem;
    font-weight: 900;
    font-size: 1.125rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
    transition: background 0.2s;
  }

  .card-cta:hover {
    background: #CC0000;
  }

  .wax-seal {
    position: absolute;
    top: -20px;
    right: 24px;
    width: 60px;
    height: 60px;
    background: #FF0000;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 900;
    font-size: 1.25rem;
    color: #FFFFFF;
    border: 3px solid #CC0000;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.4);
  }
</style>
