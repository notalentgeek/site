---
interface Props {
  direction?: "left" | "right";
}
const { direction = "left" } = Astro.props;
---
<div class={`speech-bubble speech-${direction}`}>
  <slot />
</div>
<style>
  .speech-bubble {
    position: relative;
    background: #F2E852;
    color: #0D0D0D;
    border: 4px solid #0D0D0D;
    padding: 1rem 1.5rem;
    font-weight: 700;
    text-transform: uppercase;
    clip-path: polygon(
      0 0,
      calc(100% - 8px) 0,
      100% 8px,
      100% calc(100% - 8px),
      calc(100% - 8px) 100%,
      8px 100%,
      0 calc(100% - 8px)
    );
    margin-bottom: 2rem;
  }

  .speech-bubble::after {
    content: "";
    position: absolute;
    width: 0;
    height: 0;
    border-style: solid;
  }

  .speech-left::after {
    bottom: -20px;
    left: 24px;
    border-width: 20px 20px 0 0;
    border-color: #0D0D0D transparent transparent transparent;
  }

  .speech-right::after {
    bottom: -20px;
    right: 24px;
    border-width: 0 20px 20px 0;
    border-color: transparent #0D0D0D transparent transparent;
  }
</style>
