---
import BaseLayout from "../../layouts/base_layout.astro";

interface LinkItem {
  name: string;
  url: string;
  description: string;
  icon: string;
  color: string;
}

const links: LinkItem[] = [
  {
    name: "GitHub",
    url: "https://github.com",
    description: "Open-source projects and contributions",
    icon: "GH",
    color: "#333",
  },
  {
    name: "Twitter / X",
    url: "https://twitter.com",
    description: "Thoughts on tech and design",
    icon: "TW",
    color: "#1DA1F2",
  },
  {
    name: "LinkedIn",
    url: "https://linkedin.com",
    description: "Professional profile and experience",
    icon: "LI",
    color: "#0A66C2",
  },
  {
    name: "YouTube",
    url: "https://youtube.com",
    description: "Video tutorials and talks",
    icon: "YT",
    color: "#FF0000",
  },
  {
    name: "Dribbble",
    url: "https://dribbble.com",
    description: "Design shots and explorations",
    icon: "DR",
    color: "#EA4C89",
  },
  {
    name: "Email",
    url: "mailto:hello@example.com",
    description: "Get in touch directly",
    icon: "EM",
    color: "#6366f1",
  },
];
---

<BaseLayout title="Links — Portfolio">
  <section class="mb-8">
    <h1 class="text-3xl font-bold tracking-tight text-gray-900">Links</h1>
    <p class="mt-2 text-gray-500">Find me around the internet.</p>
  </section>

  <div class="mx-auto max-w-lg flex flex-col gap-4">
    {links.map((link) => (
      <a
        href={link.url}
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-4 rounded-bento border border-neutral-border bg-neutral-card p-5 shadow-bento backdrop-blur-glass transition-all duration-300 hover:-translate-y-0.5 hover:bg-neutral-card-hover hover:shadow-bento-hover"
      >
        <span
          class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl text-sm font-bold text-white"
          style={`background-color: ${link.color};`}
        >
          {link.icon}
        </span>
        <div>
          <h2 class="font-semibold text-gray-900 transition-colors group-hover:text-accent">
            {link.name}
          </h2>
          <p class="text-sm text-gray-500">{link.description}</p>
        </div>
        <span class="ml-auto text-gray-300 transition-transform group-hover:translate-x-1">
          &rarr;
        </span>
      </a>
    ))}
  </div>
</BaseLayout>
