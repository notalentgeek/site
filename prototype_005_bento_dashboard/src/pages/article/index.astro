---
import BaseLayout from "../../layouts/base_layout.astro";
import { getCollection } from "astro:content";

const articles = (await getCollection("article")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<BaseLayout title="Articles — Portfolio">
  <section class="mb-8">
    <h1 class="text-3xl font-bold tracking-tight text-gray-900">Articles</h1>
    <p class="mt-2 text-gray-500">Thoughts, tutorials, and explorations.</p>
  </section>

  <div class="flex flex-col gap-4">
    {articles.map((article) => (
      <article class="group rounded-bento border border-neutral-border bg-neutral-card p-6 shadow-bento backdrop-blur-glass transition-all duration-300 hover:-translate-y-0.5 hover:bg-neutral-card-hover hover:shadow-bento-hover">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h2 class="text-lg font-bold text-gray-900 transition-colors group-hover:text-accent">
              {article.data.title}
            </h2>
            <p class="mt-1 text-sm text-gray-500">{article.data.description}</p>
            {article.data.tags && (
              <div class="mt-3 flex gap-2">
                {article.data.tags.map((tag: string) => (
                  <span class="rounded-full bg-accent/10 px-2.5 py-0.5 text-xs font-medium text-accent">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </div>
          <time class="shrink-0 text-sm text-gray-400">
            {article.data.date.toLocaleDateString("en-US", {
              month: "short",
              day: "numeric",
              year: "numeric",
            })}
          </time>
        </div>
      </article>
    ))}
  </div>

  {articles.length === 0 && (
    <div class="rounded-bento border border-neutral-border bg-neutral-card p-12 text-center shadow-bento backdrop-blur-glass">
      <p class="text-gray-400">No articles yet. Check back soon.</p>
    </div>
  )}
</BaseLayout>
