---
import BaseLayout from "../../layouts/base_layout.astro";
import { getCollection } from "astro:content";

const articles = (await getCollection("article")).sort(
  (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
);

// Group articles by year
const articlesByYear: Record<string, typeof articles> = {};
for (const article of articles) {
  const year = new Date(article.data.date).getFullYear().toString();
  if (!articlesByYear[year]) articlesByYear[year] = [];
  articlesByYear[year].push(article);
}
const sortedYears = Object.keys(articlesByYear).sort((a, b) => Number(b) - Number(a));
---

<BaseLayout title="Writing">
  <!-- _Index link for navigation back (Paco style) -->
  <a
    href="/"
    class="inline-block font-sans text-sm text-muted-light dark:text-muted-dark
           hover:text-ink-light dark:hover:text-ink-dark transition-colors mb-10"
  >
    _Index
  </a>

  <h1 class="font-sans text-2xl font-bold tracking-tight text-ink-light dark:text-ink-dark mb-4">
    Writing
  </h1>
  <p class="text-muted-light dark:text-muted-dark leading-relaxed mb-10">
    Long-form thinking on technology, design, and everything in between.
  </p>

  {sortedYears.map((year) => (
    <section class="mb-10">
      <h2 class="font-sans text-xs font-semibold text-muted-light dark:text-muted-dark uppercase tracking-widest mb-4">
        {year}
      </h2>
      <ul class="space-y-4">
        {articlesByYear[year].map((article) => (
          <li>
            <div class="flex items-baseline justify-between gap-4">
              <a
                href={`/writing/${article.slug}/`}
                class="font-sans text-sm font-medium truncate"
              >
                {article.data.title}
              </a>
              <time class="text-xs text-muted-light dark:text-muted-dark whitespace-nowrap font-sans">
                {new Date(article.data.date).toLocaleDateString("en-US", {
                  month: "short",
                  day: "numeric",
                })}
              </time>
            </div>
            {article.data.description && (
              <p class="text-sm text-muted-light dark:text-muted-dark mt-1 leading-relaxed">
                {article.data.description}
              </p>
            )}
          </li>
        ))}
      </ul>
    </section>
  ))}

  {articles.length === 0 && (
    <p class="text-muted-light dark:text-muted-dark text-center py-16">
      No articles yet. Check back soon.
    </p>
  )}
</BaseLayout>
