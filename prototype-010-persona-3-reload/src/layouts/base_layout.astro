---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "A Persona 3 Reload inspired portfolio" } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      /* Always-dark aquatic base */
      html {
        background-color: #0d1117;
        color: #ffffff;
      }

      body {
        font-family: "IBM Plex Sans", system-ui, -apple-system, sans-serif;
        font-weight: 400;
        position: relative;
        overflow-x: hidden;
      }

      /* Water shimmer animated gradient background */
      body::before {
        content: "";
        position: fixed;
        inset: 0;
        z-index: -1;
        background: linear-gradient(
          170deg,
          #0d1117 0%,
          #0f1a2e 25%,
          #0d1117 50%,
          #0c1929 75%,
          #0d1117 100%
        );
        background-size: 400% 400%;
        animation: water-shimmer 20s ease infinite;
      }

      @keyframes water-shimmer {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
      }

      /* Headings: light weight, wide letter-spacing */
      h1, h2, h3, h4, h5, h6 {
        font-weight: 300;
        letter-spacing: 0.05em;
      }

      /* Glass panel utility */
      .glass-panel {
        background: rgba(13, 17, 23, 0.6);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(81, 238, 252, 0.15);
        border-radius: 12px;
        padding: 1.5rem;
      }

      /* Links: cyan color, subtle glow on hover */
      a {
        color: #51eefc;
        text-decoration: none;
        transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
      }
      a:hover {
        text-shadow: 0 0 8px rgba(81, 238, 252, 0.5);
      }

      /* Slow transitions globally */
      *, *::before, *::after {
        transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
      }
    </style>
  </head>
  <body class="antialiased min-h-screen relative">
    <!-- Moon phase decoration (top-right) -->
    <div class="moon-deco" aria-hidden="true">
      <svg width="40" height="40" viewBox="0 0 40 40">
        <circle cx="20" cy="20" r="18" fill="none" stroke="#51eefc" stroke-width="1" opacity="0.4"/>
        <path d="M20 2 A18 18 0 0 1 20 38 A12 12 0 0 0 20 2" fill="#51eefc" opacity="0.3"/>
      </svg>
    </div>

    <!-- Geometric circles decoration (bottom-left) -->
    <div class="geo-deco" aria-hidden="true">
      <svg width="80" height="80" viewBox="0 0 80 80">
        <circle cx="40" cy="40" r="35" fill="none" stroke="#1269cc" stroke-width="0.5" opacity="0.3"/>
        <circle cx="40" cy="40" r="25" fill="none" stroke="#51eefc" stroke-width="0.5" opacity="0.2"/>
        <circle cx="40" cy="40" r="15" fill="none" stroke="#6d9ac7" stroke-width="0.5" opacity="0.15"/>
      </svg>
    </div>

    <!-- Main content: narrow centered column -->
    <main class="max-w-[600px] mx-auto px-6 py-16 w-full relative z-10">
      <slot />
    </main>

    <style>
      .moon-deco {
        position: fixed;
        top: 1.5rem;
        right: 1.5rem;
        z-index: 40;
        opacity: 0.6;
      }
      .geo-deco {
        position: fixed;
        bottom: 1.5rem;
        left: 1.5rem;
        z-index: 40;
        opacity: 0.4;
      }
    </style>
  </body>
</html>
