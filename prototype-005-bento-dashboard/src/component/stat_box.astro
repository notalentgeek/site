---
interface Props {
  label: string;
  value: string;
  change?: string;
  positive?: boolean;
}

const { label, value, change, positive = true } = Astro.props;
---

<div class="flex flex-col gap-1">
  <span class="text-xs font-medium uppercase tracking-wider text-gray-400">
    {label}
  </span>
  <span class="text-2xl font-bold tracking-tight text-gray-900">
    {value}
  </span>
  {change && (
    <span
      class={`text-xs font-medium ${positive ? "text-emerald-500" : "text-red-500"}`}
    >
      {positive ? "\u2191" : "\u2193"} {change}
    </span>
  )}
</div>
