---
interface Props {
  title: string;
  currentPath?: string;
}

const { title, currentPath = "/" } = Astro.props;

const navItems = [
  { label: "Projects", href: "/" },
  { label: "Articles", href: "/article/" },
  { label: "Videos", href: "/video/" },
  { label: "Links", href: "/link/" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Atelier Sora — Architecture Studio" />
    <title>{title} — Atelier Sora</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&display=swap"
      rel="stylesheet"
    />
    <style>
      html { scroll-behavior: smooth; }
      body { -webkit-font-smoothing: antialiased; }
    </style>
  </head>
  <body class="bg-surface text-ink font-sans font-light min-h-screen">
    <!-- Navigation -->
    <nav class="fixed top-0 right-0 z-50 flex items-center gap-8 px-8 py-5">
      {navItems.map((item, i) => (
        <>
          <a
            href={item.href}
            class:list={[
              "text-[0.7rem] tracking-[0.12em] uppercase no-underline transition-colors",
              currentPath === item.href ? "text-ink" : "text-ink-muted hover:text-ink",
            ]}
          >
            {item.label}
          </a>
          {i < navItems.length - 1 && (
            <span class="w-px h-3 bg-rule"></span>
          )}
        </>
      ))}
    </nav>

    <!-- Brand -->
    <a href="/" class="fixed top-0 left-0 z-50 px-8 py-5 no-underline">
      <span class="font-serif text-lg font-normal text-ink">Atelier Sora</span>
    </a>

    <!-- Main content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="max-w-[1400px] mx-auto px-8 py-16 border-t border-rule">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        <div>
          <div class="font-serif text-xl mb-3">Atelier Sora</div>
          <p class="text-sm text-ink-muted leading-relaxed max-w-[280px]">
            Architecture studio exploring material honesty
            and spatial restraint since 2018.
          </p>
        </div>
        <div>
          <h4 class="text-[0.6rem] tracking-[0.2em] uppercase text-ink-muted mb-4">Studio</h4>
          <ul class="list-none space-y-2">
            <li><a href="#" class="text-sm no-underline text-ink hover:text-accent transition-colors">About</a></li>
            <li><a href="#" class="text-sm no-underline text-ink hover:text-accent transition-colors">Team</a></li>
            <li><a href="#" class="text-sm no-underline text-ink hover:text-accent transition-colors">Careers</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-[0.6rem] tracking-[0.2em] uppercase text-ink-muted mb-4">Projects</h4>
          <ul class="list-none space-y-2">
            <li><a href="#" class="text-sm no-underline text-ink hover:text-accent transition-colors">Residential</a></li>
            <li><a href="#" class="text-sm no-underline text-ink hover:text-accent transition-colors">Cultural</a></li>
            <li><a href="#" class="text-sm no-underline text-ink hover:text-accent transition-colors">Hospitality</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-[0.6rem] tracking-[0.2em] uppercase text-ink-muted mb-4">Connect</h4>
          <ul class="list-none space-y-2">
            <li><a href="#" class="text-sm no-underline text-ink hover:text-accent transition-colors">Instagram</a></li>
            <li><a href="#" class="text-sm no-underline text-ink hover:text-accent transition-colors">LinkedIn</a></li>
            <li><a href="#" class="text-sm no-underline text-ink hover:text-accent transition-colors">Email</a></li>
          </ul>
        </div>
      </div>
      <div class="mt-12 pt-6 border-t border-rule flex justify-between items-center text-[0.7rem] text-ink-muted">
        <span>&copy; 2026 Atelier Sora Architects</span>
        <span>Ignant Architect Prototype</span>
      </div>
    </footer>
  </body>
</html>
