---
interface Props {
  title: string;
  category: string;
  description: string;
  gradient: string;
  href?: string;
}

const { title, category, description, gradient, href = "#" } = Astro.props;
---

<div class="grid grid-cols-1 md:grid-cols-2">
  <div class={`aspect-video md:aspect-auto bg-gradient-to-br ${gradient}`}></div>
  <div class="flex flex-col justify-center p-12 bg-surface-off">
    <p class="text-[0.6rem] tracking-[0.2em] uppercase text-ink-muted mb-4">
      {category}
    </p>
    <h3 class="font-serif text-2xl md:text-3xl font-light leading-snug mb-4">
      {title}
    </h3>
    <p class="text-sm text-ink-muted leading-relaxed max-w-[420px] mb-6">
      {description}
    </p>
    <a href={href} class="inline-flex items-center gap-2 text-[0.7rem] tracking-[0.12em] uppercase no-underline text-ink group/link">
      Explore project
      <span class="inline-block w-6 h-px bg-ink relative transition-all group-hover/link:w-10">
        <span class="absolute right-0 -top-[3px] w-[7px] h-[7px] border-r border-t border-ink rotate-45"></span>
      </span>
    </a>
  </div>
</div>
