---
import BaseLayout from "../../layouts/base_layout.astro";

const links = [
  {
    title: "Archinect",
    url: "archinect.com",
    description: "Architecture news and community platform.",
    category: "Resource",
  },
  {
    title: "ArchDaily",
    url: "archdaily.com",
    description: "The world's most visited architecture website.",
    category: "Publication",
  },
  {
    title: "Dezeen",
    url: "dezeen.com",
    description: "Architecture, interiors, and design magazine.",
    category: "Publication",
  },
  {
    title: "Divisare",
    url: "divisare.com",
    description: "Curated atlas of contemporary architecture.",
    category: "Archive",
  },
  {
    title: "El Croquis",
    url: "elcroquis.es",
    description: "In-depth monographic architecture journal.",
    category: "Journal",
  },
];
---

<BaseLayout title="Links" currentPath="/link/">
  <div class="max-w-[800px] mx-auto px-8 pt-32 pb-24">
    <p class="text-[0.65rem] tracking-[0.2em] uppercase text-ink-muted mb-2">Bookmarks</p>
    <h1 class="font-serif text-4xl font-light mb-12">Links</h1>

    <div class="space-y-6">
      {links.map((link) => (
        <a
          href={`https://${link.url}`}
          target="_blank"
          rel="noopener noreferrer"
          class="block group border-b border-rule pb-6 no-underline text-inherit"
        >
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-[0.6rem] tracking-[0.2em] uppercase text-ink-muted mb-1">
                {link.category}
              </p>
              <h2 class="font-serif text-xl font-normal group-hover:text-accent transition-colors mb-1">
                {link.title}
              </h2>
              <p class="text-sm text-ink-muted">{link.description}</p>
            </div>
            <span class="text-[0.7rem] text-ink-muted whitespace-nowrap mt-4">
              {link.url} &nearr;
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
