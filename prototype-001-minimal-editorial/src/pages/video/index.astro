---
import BaseLayout from "../../layouts/base_layout.astro";
import VideoEmbed from "../../component/video_embed.astro";
import { getCollection } from "astro:content";

const videos = (await getCollection("video")).sort(
  (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
);
---

<BaseLayout title="Videos — Portfolio">
  <section>
    <h1 class="font-serif text-4xl font-bold mb-4">Videos</h1>
    <p class="text-gray-600 mb-12 leading-relaxed">
      Tutorials, talks, and visual explorations.
    </p>

    <div class="space-y-14">
      {videos.map((video) => (
        <article>
          <VideoEmbed
            url={video.data.embed_url}
            title={video.data.title}
            platform={video.data.platform}
          />
          <div class="mt-4">
            <time class="text-sm text-gray-400 font-sans">
              {new Date(video.data.date).toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </time>
            <h2 class="font-serif text-xl font-semibold mt-1">
              {video.data.title}
            </h2>
            <p class="text-gray-600 mt-2 leading-relaxed">
              {video.data.description}
            </p>
            {video.data.tags && (
              <div class="flex gap-2 mt-3">
                {video.data.tags.map((tag: string) => (
                  <span class="text-xs text-gray-400 border border-gray-200 rounded-full px-3 py-1">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </div>
        </article>
      ))}
    </div>

    {videos.length === 0 && (
      <p class="text-gray-400 text-center py-16">No videos yet. Check back soon.</p>
    )}
  </section>
</BaseLayout>
