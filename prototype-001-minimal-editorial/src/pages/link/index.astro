---
import BaseLayout from "../../layouts/base_layout.astro";
import SocialLink from "../../component/social_link.astro";

const linkCategories = [
  {
    title: "Social Media",
    links: [
      { name: "GitHub", url: "https://github.com", description: "Open source projects and contributions" },
      { name: "LinkedIn", url: "https://linkedin.com", description: "Professional profile and network" },
      { name: "Twitter / X", url: "https://twitter.com", description: "Thoughts, threads, and conversations" },
      { name: "Instagram", url: "https://instagram.com", description: "Photography and visual stories" },
      { name: "TikTok", url: "https://tiktok.com", description: "Short-form video content" },
    ],
  },
  {
    title: "Content",
    links: [
      { name: "YouTube", url: "https://youtube.com", description: "Long-form video tutorials and talks" },
      { name: "Medium", url: "https://medium.com", description: "Extended writing and essays" },
      { name: "Dev.to", url: "https://dev.to", description: "Technical articles and community posts" },
    ],
  },
  {
    title: "Other",
    links: [
      { name: "Email", url: "mailto:hello@example.com", description: "Get in touch directly" },
      { name: "RSS Feed", url: "/rss.xml", description: "Subscribe to updates" },
    ],
  },
];
---

<BaseLayout title="Links — Portfolio">
  <section>
    <h1 class="font-serif text-4xl font-bold mb-4">Links</h1>
    <p class="text-gray-600 mb-12 leading-relaxed">
      All the places you can find me online.
    </p>

    {linkCategories.map((category) => (
      <div class="mb-12">
        <h2 class="font-serif text-xl font-semibold mb-4 text-gray-800">
          {category.title}
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {category.links.map((link) => (
            <SocialLink
              name={link.name}
              url={link.url}
              description={link.description}
            />
          ))}
        </div>
      </div>
    ))}
  </section>
</BaseLayout>
