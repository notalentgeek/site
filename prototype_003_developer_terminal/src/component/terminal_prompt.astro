---
interface Props {
  command?: string;
  user?: string;
  path?: string;
}

const {
  command = "",
  user = "visitor",
  path = "~",
} = Astro.props;
---

<div class="flex items-center gap-2 font-mono text-sm">
  <span class="text-terminal-green-dim">{user}@portfolio</span>
  <span class="text-terminal-gray">:</span>
  <span class="text-terminal-blue">{path}</span>
  <span class="text-terminal-white">$</span>
  {command && <span class="text-terminal-green">{command}</span>}
  <slot />
</div>
