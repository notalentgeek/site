---
import TerminalPrompt from "../component/terminal_prompt.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;

const navItems = [
  { label: "home", href: "/" },
  { label: "article", href: "/article/" },
  { label: "video", href: "/video/" },
  { label: "link", href: "/link/" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | terminal://portfolio</title>
    <style is:global>
      ::selection {
        background-color: #00ff41;
        color: #0d1117;
      }

      ::-webkit-scrollbar {
        width: 8px;
      }

      ::-webkit-scrollbar-track {
        background: #0d1117;
      }

      ::-webkit-scrollbar-thumb {
        background: #30363d;
        border-radius: 4px;
      }

      ::-webkit-scrollbar-thumb:hover {
        background: #484f58;
      }

      /* Scanline overlay effect */
      body::before {
        content: "";
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 9999;
        background: repeating-linear-gradient(
          0deg,
          rgba(0, 0, 0, 0.03) 0px,
          rgba(0, 0, 0, 0.03) 1px,
          transparent 1px,
          transparent 2px
        );
      }

      /* CRT glow effect on text */
      .glow-text {
        text-shadow: 0 0 5px rgba(0, 255, 65, 0.4),
                     0 0 10px rgba(0, 255, 65, 0.2);
      }

      /* Prose styles for markdown content */
      .terminal-prose h2 {
        color: #00ff41;
        font-size: 1.25rem;
        margin-top: 1.5rem;
        margin-bottom: 0.75rem;
        border-bottom: 1px solid #30363d;
        padding-bottom: 0.25rem;
      }

      .terminal-prose h3 {
        color: #58a6ff;
        font-size: 1.1rem;
        margin-top: 1.25rem;
        margin-bottom: 0.5rem;
      }

      .terminal-prose p {
        color: #c9d1d9;
        margin-bottom: 0.75rem;
        line-height: 1.7;
      }

      .terminal-prose ul,
      .terminal-prose ol {
        color: #c9d1d9;
        margin-bottom: 0.75rem;
        padding-left: 1.5rem;
      }

      .terminal-prose li {
        margin-bottom: 0.25rem;
      }

      .terminal-prose strong {
        color: #00ff41;
      }

      .terminal-prose code {
        background-color: #161b22;
        color: #ffa657;
        padding: 0.1rem 0.35rem;
        border-radius: 3px;
        font-size: 0.875rem;
      }

      .terminal-prose pre {
        background-color: #161b22;
        border: 1px solid #30363d;
        border-radius: 4px;
        padding: 1rem;
        overflow-x: auto;
        margin-bottom: 1rem;
      }

      .terminal-prose pre code {
        background: none;
        padding: 0;
        color: #c9d1d9;
      }

      .terminal-prose a {
        color: #58a6ff;
        text-decoration: underline;
        text-underline-offset: 2px;
      }

      .terminal-prose a:hover {
        color: #00ff41;
      }
    </style>
  </head>
  <body class="bg-terminal-bg text-terminal-green font-mono min-h-screen flex flex-col">
    <!-- ASCII Art Header -->
    <header class="border-b border-terminal-border">
      <div class="max-w-4xl mx-auto px-4 pt-6 pb-4">
        <pre class="text-terminal-green text-xs sm:text-sm leading-tight glow-text select-none" aria-hidden="true">
{`
 ____            _    __       _ _
|  _ \\ ___  _ __| |_ / _| ___ | (_) ___
| |_) / _ \\| '__| __| |_ / _ \\| | |/ _ \\
|  __/ (_) | |  | |_|  _| (_) | | | (_) |
|_|   \\___/|_|   \\__|_|  \\___/|_|_|\\___/
`}
        </pre>
        <div class="mt-2 text-terminal-gray text-xs">
          v1.0.0 | pid 1337 | uptime 99.99%
        </div>
      </div>

      <!-- Navigation -->
      <nav class="max-w-4xl mx-auto px-4 pb-3">
        <div class="flex flex-wrap gap-x-6 gap-y-1">
          {navItems.map((item) => (
            <a
              href={item.href}
              class="text-terminal-green hover:text-terminal-blue transition-colors text-sm group"
            >
              <span class="text-terminal-gray group-hover:text-terminal-blue">{">"}</span>
              {" "}{item.label}
            </a>
          ))}
        </div>
      </nav>
    </header>

    <!-- Main Content -->
    <main class="flex-1 max-w-4xl mx-auto px-4 py-6 w-full">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-terminal-border">
      <div class="max-w-4xl mx-auto px-4 py-4">
        <TerminalPrompt command="echo 'Thanks for visiting.'" />
        <div class="mt-2 text-terminal-gray text-xs">
          &copy; 2026 | Built with Astro | All rights reserved
        </div>
      </div>
    </footer>
  </body>
</html>
