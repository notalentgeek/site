---
import BaseLayout from "../../layouts/base_layout.astro";
import TerminalPrompt from "../../component/terminal_prompt.astro";
import VideoEmbed from "../../component/video_embed.astro";
import { getCollection } from "astro:content";

const videos = (await getCollection("video")).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout title="Videos">
  <section>
    <TerminalPrompt command="find ./video/ -type f -name '*.mp4' | sort -r" path="~/portfolio" />

    <div class="mt-4 space-y-6">
      {videos.length > 0 ? (
        videos.map((video) => (
          <div>
            <div class="mb-2">
              <div class="flex items-center gap-2 text-sm">
                <span class="text-terminal-amber">[vid]</span>
                <span class="text-terminal-gray">{video.data.date}</span>
                <span class="text-terminal-green">{video.data.title}</span>
              </div>
              <p class="mt-1 text-terminal-gray text-xs pl-4">
                {video.data.description}
              </p>
              {video.data.tags && (
                <div class="mt-1 pl-4 flex gap-2 flex-wrap">
                  {video.data.tags.map((tag: string) => (
                    <span class="text-terminal-amber text-xs">#{tag}</span>
                  ))}
                </div>
              )}
            </div>
            <VideoEmbed youtubeId={video.data.youtube_id} title={video.data.title} />
          </div>
        ))
      ) : (
        <div class="border border-terminal-border rounded-sm px-4 py-6 text-center text-terminal-gray text-sm">
          <p>No video files found in directory.</p>
          <p class="mt-1 text-xs">Try: <span class="text-terminal-green">touch video/first_recording.mp4</span></p>
        </div>
      )}
    </div>

    <div class="mt-4 text-xs text-terminal-gray">
      {videos.length} file(s) found
    </div>

    <div class="mt-6">
      <TerminalPrompt user="visitor" path="~/portfolio/video">
        <span class="animate-blink text-terminal-green">|</span>
      </TerminalPrompt>
    </div>
  </section>
</BaseLayout>
