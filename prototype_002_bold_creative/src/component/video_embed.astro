---
interface Props {
  title: string;
  embed_url: string;
  description?: string;
  duration?: string;
}

const { title, embed_url, description, duration } = Astro.props;
---

<div class="group rounded-2xl overflow-hidden bg-surface-light transition-all duration-500 hover:shadow-2xl hover:shadow-accent-cyan/10 hover:ring-1 hover:ring-accent-cyan/30">
  <!-- Video Container -->
  <div class="relative aspect-video bg-surface-medium overflow-hidden">
    <iframe
      src={embed_url}
      title={title}
      class="absolute inset-0 w-full h-full"
      frameborder="0"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
    ></iframe>

    <!-- Duration badge -->
    {
      duration && (
        <div class="absolute bottom-3 right-3 bg-surface/80 backdrop-blur-sm text-white text-xs font-medium px-2 py-1 rounded-md z-10">
          {duration}
        </div>
      )
    }
  </div>

  <!-- Info -->
  <div class="p-5">
    <h3 class="text-lg font-bold text-white group-hover:text-accent-cyan transition-colors duration-300 mb-2">
      {title}
    </h3>
    {
      description && (
        <p class="text-sm text-white/50 group-hover:text-white/70 transition-colors duration-300 leading-relaxed">
          {description}
        </p>
      )
    }
  </div>
</div>
