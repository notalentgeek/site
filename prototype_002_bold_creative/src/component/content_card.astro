---
interface Props {
  title: string;
  description: string;
  href?: string;
  tags?: string[];
  date?: string;
  variant?: "default" | "featured" | "compact";
}

const {
  title,
  description,
  href = "#",
  tags = [],
  date,
  variant = "default",
} = Astro.props;

const variantClasses = {
  default: "bg-surface-light",
  featured: "bg-surface-light ring-1 ring-accent-purple/20",
  compact: "bg-surface-light",
};
---

<a
  href={href}
  class:list={[
    "group block rounded-2xl p-6 transition-all duration-500 ease-out",
    "hover:scale-[1.02] hover:shadow-2xl hover:shadow-accent-purple/10",
    "hover:ring-1 hover:ring-accent-purple/30",
    "relative overflow-hidden",
    variantClasses[variant],
  ]}
>
  <!-- Hover gradient overlay -->
  <div
    class="absolute inset-0 bg-gradient-to-br from-accent-purple/0 to-accent-cyan/0 group-hover:from-accent-purple/5 group-hover:to-accent-cyan/5 transition-all duration-500 rounded-2xl"
  >
  </div>

  <!-- Content -->
  <div class="relative z-10">
    {
      date && (
        <time class="text-xs text-white/30 font-medium tracking-wider uppercase mb-3 block">
          {date}
        </time>
      )
    }

    <h3
      class:list={[
        "font-bold tracking-tight text-white group-hover:text-accent-cyan transition-colors duration-300",
        variant === "featured" ? "text-2xl mb-3" : "text-lg mb-2",
      ]}
    >
      {title}
    </h3>

    <p
      class:list={[
        "text-white/50 leading-relaxed group-hover:text-white/70 transition-colors duration-300",
        variant === "featured" ? "text-base mb-4" : "text-sm mb-3",
      ]}
    >
      {description}
    </p>

    {
      tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.map((tag) => (
            <span class="text-[11px] font-medium tracking-wider uppercase px-3 py-1 rounded-full bg-accent-purple/10 text-accent-purple-light border border-accent-purple/20 group-hover:bg-accent-purple/20 transition-colors duration-300">
              {tag}
            </span>
          ))}
        </div>
      )
    }

    <!-- Arrow indicator -->
    <div
      class="mt-4 flex items-center gap-2 text-white/20 group-hover:text-accent-cyan transition-all duration-300"
    >
      <span class="text-xs font-medium tracking-wider uppercase">Explore</span>
      <svg
        class="w-4 h-4 transform group-hover:translate-x-1 transition-transform duration-300"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
      </svg>
    </div>
  </div>
</a>
