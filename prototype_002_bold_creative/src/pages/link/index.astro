---
import BaseLayout from "../../layouts/base_layout.astro";

const socialLinks = [
  {
    name: "GitHub",
    url: "https://github.com",
    icon: "GH",
    description: "Open source projects and contributions",
    color: "from-white/10 to-white/5",
  },
  {
    name: "Twitter / X",
    url: "https://x.com",
    icon: "X",
    description: "Thoughts, threads, and hot takes",
    color: "from-accent-cyan/10 to-accent-cyan/5",
  },
  {
    name: "LinkedIn",
    url: "https://linkedin.com",
    icon: "LI",
    description: "Professional profile and career history",
    color: "from-blue-500/10 to-blue-500/5",
  },
  {
    name: "YouTube",
    url: "https://youtube.com",
    icon: "YT",
    description: "Video tutorials and creative coding streams",
    color: "from-red-500/10 to-red-500/5",
  },
  {
    name: "Dribbble",
    url: "https://dribbble.com",
    icon: "DR",
    description: "Design shots and visual explorations",
    color: "from-pink-500/10 to-pink-500/5",
  },
  {
    name: "CodePen",
    url: "https://codepen.io",
    icon: "CP",
    description: "Interactive demos and CSS experiments",
    color: "from-accent-purple/10 to-accent-purple/5",
  },
  {
    name: "Email",
    url: "mailto:hello@example.com",
    icon: "@",
    description: "Direct line for collaborations and inquiries",
    color: "from-accent-purple/10 to-accent-cyan/5",
  },
  {
    name: "RSS Feed",
    url: "/rss.xml",
    icon: "RSS",
    description: "Subscribe to the latest articles and updates",
    color: "from-orange-500/10 to-orange-500/5",
  },
];
---

<BaseLayout title="Links | Bold Creative Portfolio">
  <section class="max-w-4xl mx-auto px-6 pt-32 pb-24">
    <!-- Page Header -->
    <div class="text-center mb-16">
      <p class="text-accent-purple text-xs font-semibold tracking-[0.3em] uppercase mb-3">
        Elsewhere
      </p>
      <h1 class="text-5xl md:text-7xl font-black tracking-tighter uppercase mb-4">
        Links
      </h1>
      <p class="text-white/40 text-lg max-w-xl mx-auto leading-relaxed">
        Find me across the internet. Open for collaborations,
        conversations, and creative projects.
      </p>
    </div>

    <!-- Divider -->
    <div class="h-px bg-gradient-to-r from-transparent via-accent-purple/50 to-transparent mb-12">
    </div>

    <!-- Links Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {
        socialLinks.map((link) => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative flex items-center gap-5 p-5 rounded-2xl bg-surface-light overflow-hidden transition-all duration-500 hover:scale-[1.02] hover:shadow-2xl hover:shadow-accent-purple/10 hover:ring-1 hover:ring-accent-purple/30"
          >
            {/* Background gradient */}
            <div
              class:list={[
                "absolute inset-0 bg-gradient-to-br opacity-0 group-hover:opacity-100 transition-opacity duration-500",
                link.color,
              ]}
            />

            {/* Icon */}
            <div class="relative flex-shrink-0 w-14 h-14 rounded-xl bg-surface-medium flex items-center justify-center group-hover:bg-surface-light transition-colors duration-300">
              <span class="text-lg font-black text-white/40 group-hover:text-accent-cyan transition-colors duration-300">
                {link.icon}
              </span>
            </div>

            {/* Text */}
            <div class="relative flex-1 min-w-0">
              <h3 class="font-bold text-white group-hover:text-accent-cyan transition-colors duration-300">
                {link.name}
              </h3>
              <p class="text-sm text-white/30 group-hover:text-white/60 transition-colors duration-300 truncate">
                {link.description}
              </p>
            </div>

            {/* Arrow */}
            <div class="relative flex-shrink-0">
              <svg
                class="w-5 h-5 text-white/10 group-hover:text-accent-cyan transform group-hover:translate-x-1 transition-all duration-300"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"
                />
              </svg>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
