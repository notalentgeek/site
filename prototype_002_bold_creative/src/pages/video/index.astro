---
import BaseLayout from "../../layouts/base_layout.astro";
import VideoEmbed from "../../component/video_embed.astro";

const videos = [
  {
    title: "Creative Coding Showcase",
    description:
      "A walkthrough of generative art techniques using code as a creative medium.",
    embed_url: "https://www.youtube.com/embed/dQw4w9WgXcQ",
    duration: "12:34",
  },
  {
    title: "Design System Deep Dive",
    description:
      "Building a cohesive design system from scratch with tokens, components, and documentation.",
    embed_url: "https://www.youtube.com/embed/dQw4w9WgXcQ",
    duration: "24:10",
  },
  {
    title: "Astro Framework Walkthrough",
    description:
      "Exploring content-driven architecture and island rendering in Astro.",
    embed_url: "https://www.youtube.com/embed/dQw4w9WgXcQ",
    duration: "18:45",
  },
  {
    title: "CSS Animation Masterclass",
    description:
      "Advanced CSS techniques for smooth, performant animations without JavaScript.",
    embed_url: "https://www.youtube.com/embed/dQw4w9WgXcQ",
    duration: "31:20",
  },
];
---

<BaseLayout title="Videos | Bold Creative Portfolio">
  <section class="max-w-7xl mx-auto px-6 pt-32 pb-24">
    <!-- Page Header -->
    <div class="mb-16">
      <p class="text-accent-cyan text-xs font-semibold tracking-[0.3em] uppercase mb-3">
        Watch
      </p>
      <h1 class="text-5xl md:text-7xl font-black tracking-tighter uppercase mb-4">
        Videos
      </h1>
      <p class="text-white/40 text-lg max-w-2xl leading-relaxed">
        Tutorials, walkthroughs, and creative explorations.
        Visual learning for the modern web developer.
      </p>
    </div>

    <!-- Divider -->
    <div class="h-px bg-gradient-to-r from-accent-cyan/50 via-accent-purple/30 to-transparent mb-12">
    </div>

    <!-- Video Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {
        videos.map((video) => (
          <VideoEmbed
            title={video.title}
            description={video.description}
            embed_url={video.embed_url}
            duration={video.duration}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
