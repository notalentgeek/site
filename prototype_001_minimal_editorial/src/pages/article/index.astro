---
import BaseLayout from "../../layouts/base_layout.astro";
import { getCollection } from "astro:content";

const articles = (await getCollection("article")).sort(
  (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
);
---

<BaseLayout title="Articles — Portfolio">
  <section>
    <h1 class="font-serif text-4xl font-bold mb-4">Articles</h1>
    <p class="text-gray-600 mb-12 leading-relaxed">
      Long-form writing on technology, design, and everything in between.
    </p>

    <div class="space-y-10">
      {articles.map((article) => (
        <article class="group border-b border-gray-100 pb-10 last:border-b-0">
          <a href={`/article/${article.slug}/`} class="block">
            <time class="text-sm text-gray-400 font-sans">
              {new Date(article.data.date).toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </time>
            <h2 class="font-serif text-2xl font-semibold mt-2 group-hover:text-accent transition-colors">
              {article.data.title}
            </h2>
            <p class="text-gray-600 mt-3 leading-relaxed">
              {article.data.description}
            </p>
            {article.data.tags && (
              <div class="flex gap-2 mt-4">
                {article.data.tags.map((tag: string) => (
                  <span class="text-xs text-gray-400 border border-gray-200 rounded-full px-3 py-1">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </a>
        </article>
      ))}
    </div>

    {articles.length === 0 && (
      <p class="text-gray-400 text-center py-16">No articles yet. Check back soon.</p>
    )}
  </section>
</BaseLayout>
