---
import BaseLayout from "../layouts/base_layout.astro";
---

<BaseLayout title="Paco Coursey">
  <!-- Header -->
  <section class="pt-16 pb-20">
    <h1 class="text-base font-normal">Paco Coursey</h1>
    <p class="text-ink-muted dark:text-ink-dark-muted mt-1">
      Crafting interfaces
    </p>
  </section>

  <!-- Building -->
  <section class="pb-20">
    <h2 class="text-ink-faint dark:text-ink-dark-faint text-sm mb-6">
      Building
    </h2>
    <ul class="space-y-3">
      <li>
        <a
          href="https://linear.app"
          class="hover:underline"
          target="_blank"
          rel="noopener noreferrer"
        >
          Linear
        </a>
        <span class="text-ink-muted dark:text-ink-dark-muted">
          &mdash; Software project management
        </span>
      </li>
      <li>
        <a
          href="https://cmdk.paco.me"
          class="hover:underline"
          target="_blank"
          rel="noopener noreferrer"
        >
          cmdk
        </a>
        <span class="text-ink-muted dark:text-ink-dark-muted">
          &mdash; Fast, composable command menu
        </span>
      </li>
    </ul>
  </section>

  <!-- Projects -->
  <section class="pb-20">
    <h2 class="text-ink-faint dark:text-ink-dark-faint text-sm mb-6">
      Projects
    </h2>
    <ul class="space-y-3">
      <li>
        <a
          href="https://github.com/pacocoursey/next-themes"
          class="hover:underline"
          target="_blank"
          rel="noopener noreferrer"
        >
          next-themes
        </a>
        <span class="text-ink-muted dark:text-ink-dark-muted">
          &mdash; Perfect dark mode in Next.js
        </span>
      </li>
      <li>
        <a
          href="https://rauno.me"
          class="hover:underline"
          target="_blank"
          rel="noopener noreferrer"
        >
          rauno.me
        </a>
        <span class="text-ink-muted dark:text-ink-dark-muted">
          &mdash; Personal site for a friend
        </span>
      </li>
      <li>
        <a
          href="https://github.com/pacocoursey/paco.me"
          class="hover:underline"
          target="_blank"
          rel="noopener noreferrer"
        >
          paco.me
        </a>
        <span class="text-ink-muted dark:text-ink-dark-muted">
          &mdash; This website
        </span>
      </li>
    </ul>
  </section>

  <!-- Writing -->
  <section class="pb-20">
    <h2 class="text-ink-faint dark:text-ink-dark-faint text-sm mb-6">
      Writing
    </h2>

    <!-- 2026 -->
    <div class="mb-8">
      <h3 class="text-ink-faint dark:text-ink-dark-faint text-xs mb-4">2026</h3>
      <ul class="space-y-3">
        <li>
          <a href="/writing/" class="hover:underline">
            Hello World
          </a>
          <span class="text-ink-muted dark:text-ink-dark-muted text-sm ml-2">
            Mar
          </span>
        </li>
      </ul>
    </div>

    <!-- 2025 -->
    <div class="mb-8">
      <h3 class="text-ink-faint dark:text-ink-dark-faint text-xs mb-4">2025</h3>
      <ul class="space-y-3">
        <li>
          <a href="/writing/" class="hover:underline">
            On Design Engineering
          </a>
          <span class="text-ink-muted dark:text-ink-dark-muted text-sm ml-2">
            Nov
          </span>
        </li>
        <li>
          <a href="/writing/" class="hover:underline">
            Command Menus
          </a>
          <span class="text-ink-muted dark:text-ink-dark-muted text-sm ml-2">
            Jun
          </span>
        </li>
      </ul>
    </div>

    <a
      href="/writing/"
      class="text-ink-muted dark:text-ink-dark-muted text-sm hover:underline"
    >
      All articles &rarr;
    </a>
  </section>

  <!-- Now -->
  <section class="pb-20">
    <h2 class="text-ink-faint dark:text-ink-dark-faint text-sm mb-6">Now</h2>
    <p class="text-ink-muted dark:text-ink-dark-muted leading-relaxed">
      Interested in design systems, interaction patterns, and the craft of
      building interfaces that feel right. Spending time learning about
      typography, animation, and the small details that make software feel alive.
    </p>
  </section>

  <!-- Connect -->
  <section class="pb-20">
    <h2 class="text-ink-faint dark:text-ink-dark-faint text-sm mb-6">
      Connect
    </h2>
    <ul class="space-y-3 text-ink-muted dark:text-ink-dark-muted">
      <li>
        <a href="mailto:hello@example.com" class="hover:underline text-ink dark:text-ink-dark">
          hello@example.com
        </a>
      </li>
      <li>
        <a
          href="https://github.com"
          class="hover:underline text-ink dark:text-ink-dark"
          target="_blank"
          rel="noopener noreferrer"
        >
          GitHub
        </a>
      </li>
      <li>
        <a
          href="https://twitter.com"
          class="hover:underline text-ink dark:text-ink-dark"
          target="_blank"
          rel="noopener noreferrer"
        >
          Twitter
        </a>
      </li>
    </ul>
  </section>

  <!-- Footer -->
  <footer class="border-t border-ink-faint/20 dark:border-ink-dark-faint/20 pt-8 pb-4">
    <p class="text-ink-faint dark:text-ink-dark-faint text-sm leading-relaxed">
      "The details are not the details. They make the design."
    </p>
    <p class="text-ink-faint dark:text-ink-dark-faint text-xs mt-2">
      &mdash; Charles Eames
    </p>
  </footer>
</BaseLayout>
