---
import BaseLayout from "../../layouts/base_layout.astro";
import TerminalPrompt from "../../component/terminal_prompt.astro";

const links = [
  {
    category: "tools",
    items: [
      { title: "Neovim", url: "https://neovim.io", description: "Hyperextensible Vim-based text editor" },
      { title: "Alacritty", url: "https://alacritty.org", description: "A cross-platform, GPU-accelerated terminal emulator" },
      { title: "tmux", url: "https://github.com/tmux/tmux", description: "Terminal multiplexer for managing sessions" },
    ],
  },
  {
    category: "learning",
    items: [
      { title: "The Missing Semester", url: "https://missing.csail.mit.edu", description: "MIT course on essential dev tools" },
      { title: "Crafting Interpreters", url: "https://craftinginterpreters.com", description: "Build a programming language from scratch" },
      { title: "Learn X in Y Minutes", url: "https://learnxinyminutes.com", description: "Quick language overviews with code examples" },
    ],
  },
  {
    category: "reference",
    items: [
      { title: "DevDocs", url: "https://devdocs.io", description: "Unified API documentation browser" },
      { title: "explainshell", url: "https://explainshell.com", description: "Write down a command and get explanations" },
      { title: "crontab.guru", url: "https://crontab.guru", description: "Quick cron schedule expression editor" },
    ],
  },
];
---

<BaseLayout title="Links">
  <section>
    <TerminalPrompt command="cat ./link/bookmarks.txt" path="~/portfolio" />

    <div class="mt-4 space-y-6">
      {links.map((group) => (
        <div class="border border-terminal-border rounded-sm overflow-hidden">
          <div class="bg-terminal-bg-light px-4 py-2 border-b border-terminal-border">
            <span class="text-terminal-amber text-xs">## {group.category.toUpperCase()}</span>
          </div>
          <ul class="divide-y divide-terminal-border">
            {group.items.map((link, index) => (
              <li class="px-4 py-3 hover:bg-terminal-bg-light transition-colors">
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="block group"
                >
                  <div class="flex items-start gap-3 text-sm">
                    <span class="text-terminal-gray shrink-0">[{index}]</span>
                    <div class="min-w-0">
                      <span class="text-terminal-blue group-hover:text-terminal-green transition-colors underline underline-offset-2">
                        {link.title}
                      </span>
                      <span class="text-terminal-gray ml-2 text-xs">
                        ({new URL(link.url).hostname})
                      </span>
                      <p class="mt-0.5 text-terminal-gray text-xs">
                        {link.description}
                      </p>
                    </div>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-4 text-xs text-terminal-gray">
      {links.reduce((acc, g) => acc + g.items.length, 0)} bookmark(s) loaded
    </div>

    <div class="mt-6">
      <TerminalPrompt user="visitor" path="~/portfolio/link">
        <span class="animate-blink text-terminal-green">|</span>
      </TerminalPrompt>
    </div>
  </section>
</BaseLayout>
