---
import BaseLayout from "../../layouts/base_layout.astro";
import VideoEmbed from "../../component/video_embed.astro";
import { getCollection } from "astro:content";

const videos = (await getCollection("video"))
  .filter((v) => !v.data.draft)
  .sort(
    (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
  );
---

<BaseLayout title="Video — Alex Chen">
  <!-- Back link -->
  <p class="mb-8">
    <a
      href="/"
      class="underline decoration-link-decoration hover:decoration-link-hover
             dark:hover:decoration-link-hover-dark transition-colors"
    >By Alex Chen</a>
  </p>

  <h1 class="text-2xl font-medium mb-6">Video</h1>

  <p class="mb-10 text-muted-light dark:text-muted-dark">
    Tutorials, walkthroughs, and the occasional ramble.
  </p>

  <div class="space-y-12">
    {videos.map((video) => (
      <div>
        <p class="mb-3 font-medium">{video.data.title}</p>
        <VideoEmbed
          url={video.data.embed_url}
          title={video.data.title}
          platform={video.data.platform}
        />
      </div>
    ))}
  </div>

  {videos.length === 0 && (
    <p class="text-muted-light dark:text-muted-dark">
      No videos yet. Check back soon.
    </p>
  )}
</BaseLayout>
