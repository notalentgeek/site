---
interface Props {
  url: string;
  title: string;
  platform?: "youtube" | "tiktok";
}

const { url, title, platform = "youtube" } = Astro.props;

const isTikTok = platform === "tiktok";
const aspectClass = isTikTok
  ? "aspect-[9/16] max-w-[325px] mx-auto"
  : "aspect-video";
---

<div class={`relative w-full overflow-hidden bg-neutral-100 dark:bg-neutral-900 ${aspectClass}`}>
  <iframe
    src={url}
    title={title}
    class="absolute inset-0 w-full h-full"
    frameborder="0"
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
    allowfullscreen
    loading="lazy"
  ></iframe>
</div>
